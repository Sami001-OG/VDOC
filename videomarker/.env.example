# VDOC Configuration
# Copy this file to .env and modify as needed.
# Changing providers requires only changing these environment variables.

# --- LLM Provider ---
# Supported: openai, openrouter, groq, ollama, lm_studio, vllm, sglang
LLM_PROVIDER=openrouter
BASE_URL=https://openrouter.ai/api/v1
API_KEY=sk-or-v1-your-key-here
MODEL=qwen/qwen3-32b
VISION_MODEL=qwen/qwen2.5-vl-72b
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
MAX_TOKENS=4096
TEMPERATURE=0.1

# --- Processing ---
FRAME_EXTRACTION_FPS=1.0
MAX_FRAMES=5000
SCENE_DETECT_THRESHOLD=30.0
PARALLEL_WORKERS=4
BATCH_SIZE=16
GPU_ENABLED=false
DEVICE=cpu
FP16=false

# --- Audio ---
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=float16
LANGUAGE=
DIARIZE=false

# --- OCR ---
OCR_ENGINE=paddle
OCR_LANGUAGES=["en"]
OCR_CONFIDENCE_THRESHOLD=0.5

# --- Vision ---
VISION_ENGINE=qwen-vl

# --- Output ---
OUTPUT_FORMAT=markdirectory
EXPORT_FORMATS=["markdown","json"]
INCLUDE_KEYFRAMES=true
INCLUDE_THUMBNAILS=true
INCLUDE_EMBEDDINGS=true
OVERWRITE=false

# --- Local Mode ---
# For fully local inference, use Ollama:
# LLM_PROVIDER=ollama
# BASE_URL=http://localhost:11434/v1
# MODEL=qwen2.5:32b
# VISION_MODEL=qwen2.5-vl:72b
# GPU_ENABLED=true
# DEVICE=cuda
